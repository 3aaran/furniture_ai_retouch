# =====================================================
# frontend/.env
# 推荐本地和线上都使用 /api：
# - 本地开发：Vite proxy 转发到 http://localhost:3001
# - 线上部署：Nginx 转发到 http://127.0.0.1:3001
# =====================================================

# 【本地配置】local development
VITE_API_BASE_URL=/api

# 【线上配置】production cloud
# 上线时通常仍保持 /api，不需要改前端代码。
# VITE_API_BASE_URL=/api

# 如果后期前后端拆到不同域名，可改成独立 API 域名：
# VITE_API_BASE_URL=https://api.your-domain.com

# 安卓 APK 下载入口。手机端页面适配完成前保持关闭。
# VITE_ANDROID_APK_ENABLED=false
# VITE_ANDROID_APK_URL=https://download.xungang.xin/xungang.apk

# Windows 桌面安装包下载地址。正式环境建议使用 OSS/CDN 地址。
# VITE_WINDOWS_EXE_URL=https://download.xungang.xin/xungang-setup.exe

# 安装包版本清单。EXE/APK 壳程序会用它检查是否有新版本。
# VITE_APP_RELEASE_MANIFEST=/downloads/latest.json

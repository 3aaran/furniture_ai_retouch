# =====================================================
# backend/.env
# 使用说明：
# 1. 本地开发：取消【本地配置】注释，注释【线上配置】
# 2. 线上部署：取消【线上配置】注释，注释【本地配置】
# 3. 同一个变量不能同时出现两次未注释配置
# =====================================================

# =====================================================
# 【本地配置】local development
# =====================================================
NODE_ENV=development
APP_ENV=local
APP_NAME=家具修图
PORT=3001

# 后端公共访问地址。本地 AI 如需公网回调，可改成内网穿透/公网地址。
PUBLIC_BASE_URL=http://localhost:3001
# 允许访问后端的前端来源，多个来源用英文逗号分隔。
FRONTEND_ORIGIN=http://localhost:5173

# 本地 MySQL 连接参数。
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的本地MySQL密码
DB_NAME=furniture_ai_retouch

# JWT 签名密钥。本地可简单一些，线上必须改成 32 位以上随机字符串。
JWT_SECRET=local_dev_secret_please_change

# 本地图片存储：保存到 backend/storage，通过 /files 访问。
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=storage
LOCAL_PUBLIC_PATH=/files

# 本地 AI：mock 可先跑通业务流程；接真实平台时填写对应 Key。
AI_PROVIDER=mock
AI_API_KEY=
DASHSCOPE_API_KEY=
ALLOW_AI_FALLBACK=true

# 本地允许自动建库建表；RESET_LEGACY_TABLES 只在确认需要清理旧表时打开。
AUTO_INIT_DB=true
RESET_LEGACY_TABLES=false

# =====================================================
# 【线上配置】production cloud
# 上线时取消下面配置的 #，并注释上面的本地配置
# =====================================================
# NODE_ENV=production
# APP_ENV=production
# APP_NAME=家具修图
# PORT=3001
#
# PUBLIC_BASE_URL=https://www.your-domain.com
# FRONTEND_ORIGIN=https://www.your-domain.com
#
# DB_HOST=云MySQL内网地址或连接地址
# DB_PORT=3306
# DB_USER=furniture_app
# DB_PASSWORD=线上强密码
# DB_NAME=furniture_ai_retouch
#
# JWT_SECRET=请填写一串至少32位以上的随机字符串
#
# 对象存储：阿里云 OSS 示例。当前代码已统一 STORAGE_DRIVER 入口，启用前需接入 OSS SDK 上传实现。
# STORAGE_DRIVER=oss
# OSS_REGION=oss-cn-hangzhou
# OSS_BUCKET=your-bucket-name
# OSS_ACCESS_KEY_ID=your-access-key-id
# OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS_PUBLIC_BASE_URL=https://img.your-domain.com
#
# 对象存储：腾讯云 COS 示例。当前代码已统一 STORAGE_DRIVER 入口，启用前需接入 COS SDK 上传实现。
# STORAGE_DRIVER=cos
# COS_SECRET_ID=your-secret-id
# COS_SECRET_KEY=your-secret-key
# COS_BUCKET=your-bucket
# COS_REGION=ap-shanghai
# COS_PUBLIC_BASE_URL=https://img.your-domain.com
#
# 线上真实 AI 配置。
# AI_PROVIDER=doubao
# AI_API_KEY=your-real-ai-api-key
# DASHSCOPE_API_KEY=
# ALLOW_AI_FALLBACK=false
#
# 生产环境禁止启动时自动建库/改表/写演示数据，避免误伤客户数据。
# AUTO_INIT_DB=false
# RESET_LEGACY_TABLES=false
